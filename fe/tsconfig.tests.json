{
  "extends": "./.nuxt/tsconfig.app.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node", "bun-types"]
  },
  "include": [
    "./.nuxt/**/*.d.ts",
    "./app/**/*",
    "./shared/**/*",
    "./server/**/*",
    "./tests/**/*.ts",
    "./types/**/*.d.ts"
  ],
  "exclude": []
}
