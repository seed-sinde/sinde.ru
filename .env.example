# Copy this file to either:
#   .env.local       for local root-level compose/scripts
#   .env.production  for deploy.sh / server release
APP_ENV="local"
ENV_FILE=".env.local"
POSTGRES_HOST="127.0.0.1"
POSTGRES_PORT=5432
POSTGRES_USER="replace-with-db-user"
POSTGRES_PASSWORD="replace-with-strong-db-password"
POSTGRES_DB="replace-with-db-name"
POSTGRES_SSL="disable"
REDIS_ADDR="127.0.0.1:6379"
REDIS_PASSWORD="replace-with-strong-redis-password"
REDIS_DB=0
MINIO_ROOT_USER="replace-with-minio-root-user"
MINIO_ROOT_PASSWORD="replace-with-strong-minio-password"
MINIO_ENDPOINT="http://127.0.0.1:9000"
MINIO_MEDIA_BUCKET="media"
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
API_VERSION="v1"
NUXT_API_INTERNAL_URL="http://127.0.0.1:3001"
API_INTERNAL_URL="http://127.0.0.1:3001"
NUXT_PUBLIC_API_URL="http://127.0.0.1:3000/api/v1"
NUXT_PUBLIC_BASE_URL="http://127.0.0.1:3000"
AUTH_PUBLIC_BASE_URL="http://127.0.0.1:3000"
AUTH_ALLOWED_ORIGINS="http://127.0.0.1:3000,http://localhost:3000"
AUTH_JWT_SECRET="replace-with-random-jwt-secret"
AUTH_ENCRYPTION_SECRET="replace-with-random-encryption-secret"
AUTH_JWT_ISSUER="example.com"
AUTH_JWT_AUDIENCE="app-web"
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_HOURS=336
AUTH_VERIFY_TTL_HOURS=24
AUTH_RESET_TTL_MINUTES=30
AUTH_MFA_TICKET_TTL_MINUTES=5
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE="false"
AUTH_COOKIE_SAME_SITE="Lax"
AUTH_TOTP_ISSUER="app-name"
AUTH_PASSWORD_MIN_LENGTH=12
AUTH_REGISTER_LIMIT=10
AUTH_LOGIN_LIMIT_IP=20
AUTH_LOGIN_LIMIT_EMAIL=10
AUTH_VERIFY_REQUEST_LIMIT=5
AUTH_RESET_LIMIT=10
AUTH_RATE_WINDOW_MINUTES=15
AUTH_MAIL_FROM="no-reply@example.com"
AUTH_MAILER_DRIVER="log"
AUTH_SMTP_HOST=
AUTH_SMTP_PORT=587
AUTH_SMTP_USERNAME=
AUTH_SMTP_PASSWORD=
AUTH_SMTP_TLS_MODE="starttls"
AUTH_SMTP_HELO=
NITRO_HOST="127.0.0.1"
NITRO_PORT=3000
GO_PORT=3001
MEDIA_FILES_DIR="./be/storage/media"
MEDIA_IMAGE_MAX_BYTES=8388608
NUXT_PUBLIC_MEDIA_IMAGE_MAX_BYTES=8388608
